# GNews API key — https://gnews.io
# Free tier: 100 requests/day, used to populate the "Atualidade do Setor"
# section on /noticias-em-destaque with live Portuguese news.
GNEWS_API_KEY=
# Optional second key — used as fallback if the primary key is rate-limited
# or unauthorized. Doubles effective daily quota.
GNEWS_API_KEY_FALLBACK=
